# ──────────────────────────────────────────────
# 활성 증권사 선택: "kis" 또는 "toss"
PROVIDER=kis

# ──────────────────────────────────────────────
# 한국투자증권 API (https://apiportal.koreainvestment.com)
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=        # 계좌번호 10자리 (예: 5012345601)
KIS_IS_PAPER=true      # true=모의투자, false=실계좌

# ──────────────────────────────────────────────
# 토스증권 Open API (https://developers.tossinvest.com, 사전신청 후 발급)
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=
TOSS_ACCOUNT_NO=

# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
DART_API_KEY=
DISCORD_WEBHOOK_URL=

# ──────────────────────────────────────────────
# 매매 파라미터
MAX_POSITIONS=10
POSITION_SIZE_PCT=0.10    # 포지션당 포트폴리오 비율
MAX_DAILY_LOSS_PCT=0.05   # 일일 손실 한도 5%
STOP_LOSS_PCT=0.07        # 종목별 손절 7%
MIN_SIGNAL_SCORE=0.55     # Claude 호출 최소 신호 강도
